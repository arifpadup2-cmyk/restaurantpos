# ─── Central PostgreSQL (LAN server PC) ──────────────────────────────────────
# Change DB_HOST to the server PC's LAN IP address on every terminal.
DB_HOST=192.168.1.100
DB_PORT=5432
DB_NAME=restaurant_pos_central
DB_USER=pos_central_user
DB_PASS=change_this_password

# ─── App Identity ────────────────────────────────────────────────────────────
# Unique per physical terminal — use clear names, no spaces.
# Cash counters:   POS-01 … POS-05
# Waiter terminals: WAITER-01 … WAITER-10
MACHINE_ID=POS-01
APP_VERSION=1.1.0

# ─── Central API Server ───────────────────────────────────────────────────────
# Same LAN IP as DB_HOST, port 3001.
# Used for Socket.io notifications and auto-update checks.
API_URL=http://192.168.1.100:3001
API_KEY=change_this_api_key
