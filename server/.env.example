# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
API_KEY=change-me-to-a-random-api-key

# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a PostgreSQL plugin.
# DATABASE_URL takes priority over individual DB_* vars below.
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Individual vars (used when no DATABASE_URL):
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=restaurant_pos_central
DB_USER=pos_central_user
DB_PASS=yourpassword

# ── Admin account (created automatically on first start) ──────────────────────
ADMIN_USERNAME=arifpadup
ADMIN_PASSWORD=change-me-immediately
ADMIN_NAME=Super Admin

# ── Encryption (AES-256 for license keys stored in DB) ────────────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=change-me-to-32-chars-exactly!!

# ── Persistent storage ────────────────────────────────────────────────────────
# Railway: add a Volume at /data in the Railway dashboard, then set DATA_DIR=/data
# Without this, backups write to server/backups/ and are lost on redeploy.
DATA_DIR=/data
