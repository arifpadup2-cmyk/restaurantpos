{
  "name": "restaurant-waiter",
  "version": "1.0.0",
  "description": "Restaurant Waiter Terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.restaurant.waiter",
    "productName": "Restaurant Waiter",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "files": ["**/*", "!dist/**", "!node_modules/.cache/**"],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "generic",
      "url": "http://localhost:3001/updates/"
    }
  }
}
